<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Page de connexion / inscription -->
<VBox alignment="CENTER" spacing="15" prefWidth="400" prefHeight="500"
      style="-fx-background-color: #f0f2f5;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sn.examen_messagerie.controller.LoginController">

    <padding>
        <Insets top="40" right="50" bottom="40" left="50"/>
    </padding>

    <!-- Titre -->
    <Label text="Messagerie" style="-fx-text-fill: #128C7E; -fx-font-weight: bold;">
        <font><Font size="32"/></font>
    </Label>

    <Label text="Connectez-vous ou créez un compte" style="-fx-text-fill: #667781;">
        <font><Font size="14"/></font>
    </Label>

    <!-- Champ nom d'utilisateur -->
    <TextField fx:id="usernameField" promptText="Nom d'utilisateur"
               maxWidth="300" prefHeight="40"
               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ccc; -fx-font-size: 14;">
    </TextField>

    <!-- Champ mot de passe -->
    <PasswordField fx:id="passwordField" promptText="Mot de passe"
                   maxWidth="300" prefHeight="40"
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ccc; -fx-font-size: 14;">
    </PasswordField>

    <!-- Boutons Connexion et Inscription -->
    <HBox alignment="CENTER" spacing="15">
        <Button text="Connexion" onAction="#onLogin"
                prefWidth="135" prefHeight="40"
                style="-fx-background-color: #128C7E; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 8; -fx-cursor: hand;">
        </Button>

        <Button text="Inscription" onAction="#onRegister"
                prefWidth="135" prefHeight="40"
                style="-fx-background-color: #25D366; -fx-text-fill: white; -fx-font-size: 14; -fx-background-radius: 8; -fx-cursor: hand;">
        </Button>
    </HBox>

    <!-- Label pour afficher les messages d'erreur ou de succès -->
    <Label fx:id="statusLabel" text="" style="-fx-text-fill: red;">
        <font><Font size="13"/></font>
    </Label>

</VBox>
